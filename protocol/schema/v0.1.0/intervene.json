{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rocket-surgeon.dev/protocol/v0.1.0/intervene.json",
  "title": "intervene",
  "description": "Domain verb: set, clear, or list surgical interventions on the forward pass. Method name: 'rocket/intervene'.",

  "$defs": {
    "Request": {
      "type": "object",
      "description": "JSON-RPC 2.0 params for the 'rocket/intervene' method.",
      "properties": {
        "action": {
          "type": "string",
          "enum": ["set", "clear", "list"],
          "description": "'set' installs an intervention, 'clear' removes one by ID, 'list' returns all active interventions."
        },
        "recipe": {
          "$ref": "common.json#/$defs/InterventionRecipe",
          "description": "The intervention to install. Required when action is 'set'."
        },
        "intervention_id": {
          "type": "string",
          "description": "ID of the intervention to remove. Required when action is 'clear'."
        }
      },
      "required": ["action"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "action": { "const": "set" } },
            "required": ["action"]
          },
          "then": {
            "required": ["recipe"]
          }
        },
        {
          "if": {
            "properties": { "action": { "const": "clear" } },
            "required": ["action"]
          },
          "then": {
            "required": ["intervention_id"]
          }
        }
      ]
    },

    "Response": {
      "type": "object",
      "description": "JSON-RPC 2.0 result for 'rocket/intervene'. State status will be 'stopped' on success.",
      "properties": {
        "state": {
          "$ref": "common.json#/$defs/SessionState"
        },
        "data": {
          "type": "object",
          "properties": {
            "active_interventions": {
              "type": "array",
              "items": { "$ref": "common.json#/$defs/InterventionRecipe" },
              "description": "All currently active interventions after this operation."
            },
            "applied": {
              "type": ["boolean", "null"],
              "description": "Whether the recipe was successfully applied. Non-null only for action 'set'."
            }
          },
          "required": ["active_interventions", "applied"],
          "additionalProperties": false
        }
      },
      "required": ["state", "data"],
      "additionalProperties": false
    }
  }
}
